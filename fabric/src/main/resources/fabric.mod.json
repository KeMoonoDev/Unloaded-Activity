{
  "schemaVersion": 1,
  "id": "unloadedactivity",
  "version": "${version}",

  "custom": {
    "lithium:options": {
      "world.block_entity_ticking.sleeping.furnace": false
    }
  },

  "name": "Unloaded Activity",
  "description": "Make certain blocks such as crops grow as if they've always grown when put into simulation distance.",
  "authors": [
    "Moono"
  ],
  "contact": {
    "homepage": "https://unloadedactivity.moono.dev",
    "sources": "https://github.com/KeMoonoDev/Unloaded-Activity",
    "issues": "https://github.com/KeMoonoDev/Unloaded-Activity/issues"
  },

  "license": "GNU LGPLv3",
  "icon": "icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.moono.unloadedactivity.fabric.UnloadedActivityFabric"
    ]
  },
  "mixins": [
    "unloadedactivity.mixins.json",
    "unloadedactivityfabric.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "minecraft": "${compatible_versions_fabric}",
    "java": ">=17"
  },
  "suggests": {
    "another-mod": "*"
  }
}
